{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=license_manager;Username=postgres;Password=postgres;SSL Mode=Prefer;",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Secret": "ChangeThisVerySecure256BitSecretKeyInProductionItMustBeAtLeast32CharactersLong",
    "Issuer": "LicenseManagerAPI",
    "Audience": "LicenseManagerClient",
    "ExpiryMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:3001",
      "http://localhost:3002"
    ]
  },
  "Hangfire": {
    "DashboardPath": "/hangfire",
    "WorkerCount": 0,
    "Queues": [ "critical", "default", "low" ],
    "SchemaName": "hangfire",
    "PrepareSchemaIfNecessary": true,
    "DashboardRequireAuth": true,
    "RecurringJobs": {
      "LicenseExpiryReminder": "0 9 * * *",
      "LicenseExpiryWarning30Days": "15 9 * * *",
      "LicenseExpiryWarning7Days": "30 9 * * *",
      "DailyLicenseValidation": "0 2 * * *",
      "DailyCleanup": "0 3 * * *",
      "AuditLogCleanup": "0 4 * * 0",
      "NotificationQueueProcessor": "*/5 * * * *",
      "FailedNotificationRetry": "*/30 * * * *"
    },
    "Retention": {
      "ApiLogDays": 30,
      "LicenseValidationDays": 90,
      "AuditLogDays": 365
    },
    "ExpiryWindows": {
      "ReminderDays": 60,
      "Warning30Days": 30,
      "Warning7Days": 7
    }
  },
  "AllowedHosts": "*"
}
