*.vssscc
.builds
*.pidb
*.svclog
*.scc

# NuGet Packages
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/
*.nuget.props
*.nuget.targets

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.yarn/
dist/
build/
.next/
out/

# Flutter
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
pubspec.lock

# Docker
*.log

# Environment variables
.env
.env.local
.env.*.local
appsettings.Development.json
appsettings.Local.json

# Database
*.db
*.db-shm
*.db-wal

# Secrets
secrets/
*.key
*.pem
*.pfx

# OS
.DS_Store
Thumbs.db
